# =============================================================================
# Super AI Gateway — Environment Variables
# Copy to .env and fill in your API keys
# Multi-key rotation: separate keys with commas (e.g. GROQ_API_KEY=k1,k2,k3)
# =============================================================================

# ---- FREE TIER PROVIDERS ----

# Groq (30 RPM, 6K TPM per key)
GROQ_API_KEY=

# Cerebras (30 RPM, 1M tokens/day per key)
CEREBRAS_API_KEY=

# DeepSeek (1M tokens/day, free tier)
DEEPSEEK_API_KEY=

# Cloudflare Workers AI (10K neurons/day free)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare AI Gateway (100K req/day free, requires Workers Paid for scale)
CLOUDFLARE_GATEWAY_KEY=

# Novita AI ($0.50 trial credit, 60 RPM)
NOVITA_API_KEY=

# Chutes (community GPU, 500K tokens/day free)
CHUTES_API_KEY=

# NVIDIA NIM (free via Developer Program — sign up at build.nvidia.com)
NVIDIA_NIM_API_KEY=

# ---- PAID / HYBRID PROVIDERS ----

# OpenCode Zen + Go (free models available)
OPENCODE_API_KEY=

# OpenRouter (free models available with rate limits)
OPENROUTER_API_KEY=

# NanoGPT (pay per prompt)
NANOGPT_API_KEY=

# Vercel AI Gateway ($5/mo free credit)
VERCEL_AI_GATEWAY_KEY=

# Ollama Cloud (free tier available)
OLLAMA_API_KEY=

# ---- PROXY (optional) ----
# DataImpulse residential proxy for key rotation pools
# PROXY_URL=socks5://user:pass@proxy.dataimpulse.com:1080
